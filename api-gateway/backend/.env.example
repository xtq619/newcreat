# 数据库连接
DATABASE_URL=postgresql+asyncpg://gateway:gateway_secret@localhost:5432/api_gateway
DATABASE_URL_SYNC=postgresql://gateway:gateway_secret@localhost:5432/api_gateway

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# JWT 配置
SECRET_KEY=请替换为随机生成的密钥
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# API Key 前缀
API_KEY_PREFIX=sk-

# Fernet 加密密钥（用于加密存储上游模型的 API Key）
# 生成方式：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=请运行上面的命令生成并替换

# 调试模式
DEBUG=true
