# ============================================
# 本地开发环境配置（复制为 .env 后修改）
# 生产环境的 .env 放在 /opt/api-gateway/.env，由 docker-compose.prod.yml 读取
# ============================================

# 数据库连接（本地开发用 localhost，Docker 内用 postgres 容器名）
DATABASE_URL=postgresql+asyncpg://gateway:gateway_secret@localhost:5432/api_gateway
DATABASE_URL_SYNC=postgresql://gateway:gateway_secret@localhost:5432/api_gateway

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# JWT 签名密钥（随机生成一个长字符串）
SECRET_KEY=请替换为随机生成的密钥
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# API Key 前缀
API_KEY_PREFIX=sk-

# Fernet 加密密钥（用于加密存储上游模型的 API Key）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=请运行上面的命令生成并替换

# 调试模式（生产环境设为 false）
DEBUG=true

# ---------- 以下仅生产环境需要 ----------

# 域名（用于 CORS 和前端构建）
# DOMAIN=xtq619.xyz

# 微信小程序（小程序登录需要）
# WX_APPID=your_wx_appid
# WX_SECRET=your_wx_secret
