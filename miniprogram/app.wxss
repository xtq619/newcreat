/* ===== 全局变量 ===== */
page {
  --bg: #080808;
  --surface: #141414;
  --border: #2a2a2a;
  --text: #f6f3ec;
  --text-muted: #948e83;
  --text-dim: #5a5650;
  --accent: #dba460;
  --accent-dim: rgba(219, 164, 96, 0.15);
  --danger: #e05252;

  background: #060606;
  color: #f6f3ec;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ===== 毛玻璃卡片 ===== */
.glass-card {
  background: rgba(12, 16, 24, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(20px);
}

.glass-card-bright {
  background: rgba(30, 35, 50, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 24rpx;
  padding: 32rpx;
}

/* ===== 按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #dba460, #c4914e);
  color: #000;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.06);
  color: var(--text);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  background: rgba(224, 82, 82, 0.15);
  color: #e05252;
  border: 1rpx solid rgba(224, 82, 82, 0.3);
  border-radius: 16rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  text-align: center;
}

.btn-danger::after {
  border: none;
}

/* ===== 输入框 ===== */
.input-field {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: var(--text);
  font-size: 26rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ===== 页面容器 ===== */
.page-container {
  padding: 32rpx;
  min-height: 100vh;
  position: relative;
  background: #060606;
}

/* ===== 分割线 ===== */
.divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.06);
}

.divider-text {
  font-size: 22rpx;
  color: var(--text-dim);
}

/* ===== 标签 ===== */
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.tag-blue {
  background: rgba(96, 165, 250, 0.1);
  border: 1rpx solid rgba(96, 165, 250, 0.3);
  color: #60a5fa;
}

.tag-purple {
  background: rgba(167, 139, 250, 0.1);
  border: 1rpx solid rgba(167, 139, 250, 0.3);
  color: #a78bfa;
}

.tag-green {
  background: rgba(74, 222, 128, 0.1);
  border: 1rpx solid rgba(74, 222, 128, 0.3);
  color: #4ade80;
}

/* ===== 状态圆点 ===== */
.dot-active {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4ade80;
  display: inline-block;
}

.dot-inactive {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--text-dim);
  display: inline-block;
}

/* ===== Scroll 容器 ===== */
.scroll-container {
  height: 100vh;
}
