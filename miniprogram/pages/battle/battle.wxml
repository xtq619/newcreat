<view class="page-container">
  <image class="bg" src="https://xtq619.xyz/bg-auth.png" mode="aspectFill"/>

  <!-- Config -->
  <view class="glass-card config-section" wx:if="{{!running && !done}}">
    <!-- 两位辩手头像 -->
    <view class="debaters">
      <view class="debater">
        <image class="debater-avatar" src="https://xtq619.xyz/debater-a.png" mode="aspectFill"/>
        <text class="debater-name">正方</text>
      </view>
      <text class="vs-text">VS</text>
      <view class="debater">
        <image class="debater-avatar" src="https://xtq619.xyz/debater-b.png" mode="aspectFill"/>
        <text class="debater-name">反方</text>
      </view>
    </view>

    <view class="config-field">
      <text class="config-label">讨论主题</text>
      <input class="input-field" placeholder="输入讨论主题..." bindinput="onTopicInput" value="{{topic}}"/>
    </view>

    <button class="btn-primary start-btn" bindtap="startBattle">开始讨论</button>
  </view>

  <!-- Battle results -->
  <view class="battle-results" wx:if="{{turns.length > 0}}">
    <view class="turn glass-card-bright" wx:for="{{turns}}" wx:key="round">
      <view class="turn-header">
        <view class="turn-debater">
          <image class="turn-avatar" src="{{item.model === 'a' ? 'https://xtq619.xyz/debater-a.png' : 'https://xtq619.xyz/debater-b.png'}}" mode="aspectFill"/>
          <text class="turn-model model-{{item.model}}">{{item.model === 'a' ? '正方' : '反方'}} · 第{{item.round}}轮</text>
        </view>
      </view>
      <text class="turn-content">{{item.content}}</text>
    </view>

    <view wx:if="{{judgeSummary}}" class="judge-card glass-card">
      <text class="judge-label">总结</text>
      <text class="judge-content">{{judgeSummary}}</text>
    </view>

    <view wx:if="{{running}}" class="loading-indicator">
      <text class="loading-text">讨论进行中...</text>
    </view>
  </view>

  <!-- History toggle -->
  <view class="history-toggle" bindtap="toggleHistory">
    <text class="toggle-text">{{showHistory ? '收起历史' : '查看历史讨论'}} ({{history.length}})</text>
  </view>

  <view wx:if="{{showHistory}}" class="history-list">
    <view class="glass-card history-item" wx:for="{{history}}" wx:key="id" data-id="{{item.id}}" bindtap="viewHistoryDetail">
      <text class="history-topic">{{item.topic}}</text>
      <text class="history-meta">正方 vs 反方 · {{item.rounds}}轮</text>
      <text class="history-time">{{item.created_at}}</text>
    </view>
    <view wx:if="{{history.length === 0}}" class="empty">
      <text class="empty-text">暂无历史讨论</text>
    </view>
  </view>
</view>
