.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.page-container {
  padding-top: 180rpx;
  padding-bottom: 120rpx;
}

.page-container > view {
  position: relative;
  z-index: 1;
}

.config-section {
  margin-bottom: 24rpx;
  backdrop-filter: none;
  background: rgba(20, 24, 36, 0.95);
}

.config-section .input-field {
  background: #1e2536;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: #fff;
  height: 80rpx;
  line-height: 80rpx;
}

/* === 辩手头像 === */
.debaters {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 32rpx;
}

.debater {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.debater-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.debater-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
}

.vs-text {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.3);
  margin: 0 48rpx;
}

/* === 讨论结果 === */
.config-field {
  margin-bottom: 24rpx;
}

.config-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.start-btn {
  margin-top: 8rpx;
}

.turn {
  margin-bottom: 16rpx;
  padding: 28rpx;
}

.turn-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.turn-debater {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.turn-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.turn-model {
  font-size: 24rpx;
  font-weight: 600;
}

.model-a {
  color: #60a5fa;
}

.model-b {
  color: #f97316;
}

.turn-content {
  display: block;
  font-size: 26rpx;
  color: rgba(235, 230, 220, 0.9);
  line-height: 1.6;
}

.judge-card {
  margin-top: 16rpx;
  border-color: rgba(219, 164, 96, 0.3);
}

.judge-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 12rpx;
}

.judge-content {
  display: block;
  font-size: 26rpx;
  color: rgba(235, 230, 220, 0.9);
  line-height: 1.6;
}

.loading-indicator {
  text-align: center;
  padding: 32rpx;
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-dim);
}

/* === 历史记录 === */
.history-toggle {
  text-align: center;
  padding: 24rpx;
  margin-top: 16rpx;
}

.toggle-text {
  font-size: 24rpx;
  color: var(--accent);
}

.history-item {
  margin-bottom: 12rpx;
  padding: 24rpx;
}

.history-topic {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4rpx;
}

.history-meta {
  display: block;
  font-size: 22rpx;
  color: var(--text-dim);
  margin-bottom: 4rpx;
}

.history-time {
  display: block;
  font-size: 20rpx;
  color: var(--text-dim);
}

.empty {
  text-align: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-dim);
}
