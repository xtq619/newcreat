<view class="profile-page">
  <image class="bg" src="https://xtq619.xyz/bg-auth.png" mode="aspectFill"/>

  <view class="profile-content">
    <!-- 未登录：弹窗式登录 -->
    <view wx:if="{{!isLoggedIn}}" class="login-card">
      <text class="login-title">登录账号</text>

      <view class="avatar-wrap">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{tempAvatar}}" class="avatar-img" src="{{tempAvatar}}" mode="aspectFill"/>
          <view wx:else class="avatar-placeholder">
            <text class="avatar-icon">头像</text>
          </view>
        </button>
      </view>

      <input class="nickname-input" type="nickname" placeholder="点击获取微信昵称" value="{{tempNickname}}" bindinput="onNicknameInput"/>

      <button class="login-btn" bindtap="wxLogin" loading="{{loading}}">
        <text>确认登录</text>
      </button>
    </view>

    <!-- 已登录 -->
    <view wx:if="{{isLoggedIn}}" class="logged-section">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"/>
      <view wx:else class="avatar">{{userName}}</view>

      <text class="profile-name">{{userEmail || '微信用户'}}</text>

      <view class="profile-btn logout" bindtap="logout">
        <text>退出登录</text>
      </view>

      <!-- 给开发者留言 -->
      <view class="feedback-section">
        <view class="feedback-header">
          <text class="feedback-title">给开发者留言</text>
          <text class="feedback-subtitle">你的留言仅开发者可见</text>
        </view>

        <view class="feedback-form">
          <textarea
            class="feedback-textarea"
            placeholder="写下你想对开发者说的话..."
            placeholder-class="feedback-placeholder"
            maxlength="500"
            bindinput="onFeedbackInput"
            value="{{feedbackContent}}"
          />
          <button class="feedback-submit-btn" bindtap="submitFeedback" loading="{{feedbackSubmitting}}">
            <text>发送</text>
          </button>
        </view>

        <!-- 历史留言 -->
        <view class="feedback-list" wx:if="{{feedbackItems.length > 0}}">
          <view class="feedback-item" wx:for="{{feedbackItems}}" wx:key="id">
            <view class="feedback-item-header">
              <text class="feedback-time">{{item.created_at}}</text>
              <text class="feedback-delete" data-id="{{item.id}}" bindtap="deleteFeedback">删除</text>
            </view>
            <text class="feedback-content">{{item.content}}</text>
            <view wx:if="{{item.reply}}" class="feedback-reply">
              <text class="reply-label">开发者回复：</text>
              <text class="reply-content">{{item.reply}}</text>
            </view>
          </view>
        </view>

        <view class="feedback-empty" wx:if="{{!feedbackLoading && feedbackItems.length === 0}}">
          <text class="feedback-empty-text">暂无留言</text>
        </view>
      </view>
    </view>
  </view>
</view>
