.profile-page {
  min-height: 100vh;
  position: relative;
  background: #060606;
}

.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.profile-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

/* === 登录卡片 === */
.login-card {
  width: 560rpx;
  background: rgba(8, 10, 18, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(40px);
}

.login-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #f6f3ec;
  margin-bottom: 40rpx;
}

.avatar-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.avatar-btn {
  width: 128rpx;
  height: 128rpx;
  min-width: 128rpx;
  min-height: 128rpx;
  max-width: 128rpx;
  max-height: 128rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  overflow: hidden;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-btn::after {
  border: none;
  padding: 0;
  margin: 0;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx dashed rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.nickname-input {
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  color: #f6f3ec;
  padding: 16rpx 0;
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.login-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dba460, #c4914e);
  border-radius: 16rpx;
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  padding: 26rpx 0;
}

.login-btn::after {
  border: none;
}

/* === 已登录 === */
.logged-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 640rpx;
  padding: 0 32rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.profile-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
}

.profile-btn {
  padding: 24rpx 64rpx;
  border-radius: 16rpx;
}

.profile-btn text {
  font-size: 28rpx;
}

.profile-btn.logout {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.profile-btn.logout text {
  color: rgba(255, 255, 255, 0.5);
}

/* === 给开发者留言 === */
.feedback-section {
  width: 100%;
  margin-top: 60rpx;
}

.feedback-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 28rpx;
  padding-left: 8rpx;
}

.feedback-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #f6f3ec;
}

.feedback-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

.feedback-form {
  background: rgba(8, 10, 18, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  backdrop-filter: blur(20px);
}

.feedback-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #f6f3ec;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.feedback-placeholder {
  color: rgba(255, 255, 255, 0.25);
  font-size: 26rpx;
}

.feedback-submit-btn {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dba460, #c4914e);
  border-radius: 12rpx;
  color: #000;
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 0;
}

.feedback-submit-btn::after {
  border: none;
}

/* 历史留言 */
.feedback-list {
  width: 100%;
  margin-top: 32rpx;
}

.feedback-item {
  background: rgba(8, 10, 18, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  backdrop-filter: blur(20px);
}

.feedback-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.feedback-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

.feedback-delete {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  padding: 4rpx 0;
}

.feedback-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.6;
  word-break: break-all;
}

.feedback-reply {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.reply-label {
  font-size: 22rpx;
  color: #dba460;
}

.reply-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.6;
  display: block;
  margin-top: 6rpx;
}

.feedback-empty {
  margin-top: 32rpx;
  text-align: center;
}

.feedback-empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.2);
}
