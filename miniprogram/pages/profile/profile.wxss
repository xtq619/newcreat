.profile-page {
  min-height: 100vh;
  position: relative;
  background: #060606;
}

.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.profile-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}

/* === 登录卡片 === */
.login-card {
  width: 560rpx;
  background: rgba(8, 10, 18, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(40px);
}

.login-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #f6f3ec;
  margin-bottom: 40rpx;
}

.avatar-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.avatar-btn {
  width: 128rpx;
  height: 128rpx;
  min-width: 128rpx;
  min-height: 128rpx;
  max-width: 128rpx;
  max-height: 128rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  overflow: hidden;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-btn::after {
  border: none;
  padding: 0;
  margin: 0;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx dashed rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.nickname-input {
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  color: #f6f3ec;
  padding: 16rpx 0;
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.login-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dba460, #c4914e);
  border-radius: 16rpx;
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  padding: 26rpx 0;
}

.login-btn::after {
  border: none;
}

/* === 已登录 === */
.logged-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.profile-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 60rpx;
}

.profile-btn {
  padding: 24rpx 64rpx;
  border-radius: 16rpx;
}

.profile-btn text {
  font-size: 28rpx;
}

.profile-btn.logout {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.profile-btn.logout text {
  color: rgba(255, 255, 255, 0.5);
}
