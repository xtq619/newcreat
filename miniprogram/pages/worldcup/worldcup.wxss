.wc-page {
  min-height: 100vh;
  background: #060606;
  position: relative;
}

.wc-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* === 顶部标题 === */
.wc-hero {
  position: relative;
  z-index: 1;
  padding: 200rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wc-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #f6f3ec;
  letter-spacing: 4rpx;
}

.wc-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
  letter-spacing: 4rpx;
}

.countdown {
  margin-top: 24rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.countdown-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #dba460;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.countdown-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.countdown-live {
  font-size: 36rpx;
  font-weight: 600;
  color: #4ade80;
}

/* === 二级 Tab === */
.sub-tabs {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  gap: 8rpx;
  padding: 0 48rpx 32rpx;
}

.sub-tab {
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.sub-tab.active {
  color: #000;
  background: #dba460;
  border-color: #dba460;
}

/* === 内容区 === */
.tab-content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx 160rpx;
}

/* === 筛选行 === */
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-btn {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.filter-btn.active {
  color: #dba460;
  border-color: rgba(219, 164, 96, 0.4);
  background: rgba(219, 164, 96, 0.1);
}

/* === 日期分组 === */
.date-header {
  padding: 20rpx 0 12rpx;
}

.date-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  font-family: 'SF Mono', 'Menlo', monospace;
  letter-spacing: 2rpx;
}

/* === 比赛卡片 === */
.match-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.match-stage {
  margin-bottom: 12rpx;
}

.match-stage text {
  font-size: 20rpx;
  color: #dba460;
  padding: 4rpx 12rpx;
  background: rgba(219, 164, 96, 0.1);
  border: 1rpx solid rgba(219, 164, 96, 0.25);
  border-radius: 8rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.match-teams {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.match-teams.compact {
  gap: 12rpx;
  justify-content: center;
  padding: 8rpx 0;
}

.team-side {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.team-right {
  justify-content: flex-end;
  text-align: right;
}

.team-flag {
  font-size: 40rpx;
}

.team-name {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.team-name-sm {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
}

.match-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.match-score {
  font-size: 36rpx;
  font-weight: 700;
  color: #dba460;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.match-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  font-family: 'SF Mono', 'Menlo', monospace;
}

.match-tz {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
  margin-top: 4rpx;
}

.match-time-sm {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-family: 'SF Mono', 'Menlo', monospace;
}

.match-live {
  font-size: 24rpx;
  color: #4ade80;
  font-weight: 600;
}

.match-vs {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.2);
  font-weight: 600;
  margin: 0 16rpx;
}

/* === 竞猜 === */
.guess-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #dba460;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}

.guess-inputs {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.guess-score {
  width: 72rpx;
  height: 72rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.guess-sep {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}

.guess-submit {
  margin-top: 16rpx;
  font-size: 24rpx;
  padding: 14rpx 0;
}

.guess-result {
  margin-top: 12rpx;
  text-align: center;
}

.result-correct {
  font-size: 24rpx;
  color: #4ade80;
}

.result-wrong {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* === 情绪 === */
.emotion-options {
  display: flex;
  justify-content: space-around;
  margin: 16rpx 0;
}

.emotion-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.emotion-btn.selected {
  background: rgba(219, 164, 96, 0.12);
  border-color: rgba(219, 164, 96, 0.4);
}

.emotion-emoji {
  font-size: 36rpx;
}

.emotion-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 情绪统计条 */
.emotion-bars {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.emotion-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.bar-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  width: 120rpx;
}

.bar-track {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #dba460, #c4914e);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.bar-pct {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  width: 60rpx;
  text-align: right;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* === 分析 === */
.analysis-content {
  margin-top: 16rpx;
}

.strength-bar {
  position: relative;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.strength-a {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, #60a5fa, #3b82f6);
  border-radius: 4rpx;
}

.strength-label-a {
  position: absolute;
  left: 0;
  top: -36rpx;
  font-size: 20rpx;
  color: #60a5fa;
}

.strength-label-b {
  position: absolute;
  right: 0;
  top: -36rpx;
  font-size: 20rpx;
  color: #f97316;
}

.analysis-section {
  margin-bottom: 16rpx;
}

.analysis-title {
  display: block;
  font-size: 22rpx;
  color: #dba460;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.6;
}

.analysis-placeholder {
  padding: 32rpx 0;
  text-align: center;
}

.placeholder-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.25);
}
