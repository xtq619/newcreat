.hub-page {
  min-height: 100vh;
  background: #060606;
  position: relative;
}

.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.ambient {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at 50% 45%, rgba(100,160,220,0.06) 0%, transparent 50%),
              radial-gradient(ellipse at 50% 60%, rgba(219,164,96,0.03) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* === 顶部品牌区 === */
.hero {
  position: relative;
  z-index: 1;
  padding: 620rpx 0 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-title {
  font-size: 68rpx;
  font-weight: 400;
  color: #f6f3ec;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 36rpx;
  font-weight: 300;
  letter-spacing: 16rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* === 内容区域 === */
.scroll-area {
  position: relative;
  z-index: 1;
}

/* === 小标题 === */
.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0 48rpx;
  padding: 0 60rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(219,164,96,0.3), transparent);
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 8rpx;
  padding: 0 32rpx;
}

/* === 时间线 === */
.timeline {
  position: relative;
  padding: 0 48rpx 0 68rpx;
}

.timeline-line {
  position: absolute;
  left: 68rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: linear-gradient(180deg, rgba(219,164,96,0.5), rgba(219,164,96,0.1), transparent);
}

.timeline-node {
  position: relative;
  margin-bottom: 48rpx;
}

.node-dot {
  position: absolute;
  left: -36rpx;
  top: 32rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #dba460;
  box-shadow: 0 0 12rpx rgba(219,164,96,0.4);
}

.node-card {
  background: rgba(10, 10, 14, 0.75);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  overflow: hidden;
}

.node-img-placeholder {
  width: 100%;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.node-img {
  width: 100%;
  height: 300rpx;
  display: block;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.node-img-bg {
  width: 100%;
  height: 300rpx;
  background-size: cover;
  background-position: center top;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.node-img-text {
  font-size: 80rpx;
  opacity: 0.5;
}

.node-info {
  padding: 28rpx 32rpx;
}

.node-year {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 24rpx;
  color: #dba460;
  letter-spacing: 2rpx;
}

.node-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #f6f3ec;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}

.node-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.7;
}

/* === 我的想法 === */
.thoughts-card {
  margin: 0 48rpx 32rpx;
  padding: 36rpx;
  background: rgba(10, 10, 14, 0.75);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.thoughts-label {
  display: block;
  font-size: 24rpx;
  color: #dba460;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.thoughts-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.8;
}

.bottom-space {
  height: 160rpx;
}
