.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.page-container {
  padding-top: 180rpx;
  padding-bottom: 120rpx;
}

.page-container > view {
  position: relative;
  z-index: 1;
}

.submit-section {
  margin-bottom: 32rpx;
}

.input-area {
  width: 100%;
  min-height: 160rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: var(--text);
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.placeholder {
  color: rgba(255, 255, 255, 0.25);
}

.submit-btn {
  width: 100%;
}

.feedback-item {
  margin-bottom: 12rpx;
  padding: 24rpx;
}

.feedback-content {
  display: block;
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.feedback-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.feedback-time {
  font-size: 20rpx;
  color: var(--text-dim);
}

.feedback-delete {
  font-size: 22rpx;
  color: var(--danger);
}

.reply-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.reply-label {
  display: block;
  font-size: 22rpx;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.reply-content {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-dim);
}
